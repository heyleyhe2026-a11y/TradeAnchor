---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import RiskDisclaimer from '../components/RiskDisclaimer.astro';

import { t as enT } from '../i18n/en';
import { t as zhT } from '../i18n/zh';

const lang = Astro.url.pathname.startsWith('/zh') ? 'zh' : 'en';
const t = lang === 'zh' ? zhT : enT;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);

const termsContent = lang === 'zh'
  ? {
      title: '服务条款',
      lastUpdated: '最后更新：2026 年 6 月 5 日',
      sections: [
        {
          heading: '1. 服务说明',
          items: [
            'TradeAnchor（以下简称"本平台"）是一个交易分析、社区互动和 AI 辅助决策工具。',
            '本平台提供但不限于以下功能：交易记录管理、AI 报告生成、社区内容分享、积分系统等。',
            '用户注册即表示同意遵守本条款的全部内容。',
          ],
        },
        {
          heading: '2. 用户账户',
          items: [
            '用户须提供真实、准确、完整的注册信息。',
            '用户有责任保护账户安全，对账户下所有活动负责。',
            '如发现账户被未授权使用，应立即通知我们。',
          ],
        },
        {
          heading: '3. 积分获取与消耗',
          items: [
            '积分是本平台内的虚拟激励单位，仅用于在本网站内解锁和使用各项功能服务。',
            '积分获取：用户可通过完成"成长计划"中的各类任务获得积分奖励，包括但不限于：首次浏览帖子、创建交易记录、发布社区帖子、撰写交易日记等。具体任务及对应积分奖励以成长计划页面实时展示为准。',
            '积分消耗：用户使用 AI 报告生成、AI 追问对话、付费阅读社区内容等功能时，将按相应标准扣除账户内可用积分。各功能的具体消耗量以操作时的提示为准。',
            '积分不可提现、不可转让、不可赠予第三方，不具任何现金价值。',
            '积分无法通过充值或任何付费方式增加。用户在本站内所获得的所有积分仅限于本网站内消耗使用，不得兑换为现金或实物商品。',
            '本平台保留根据运营需要调整积分获取规则和消耗标准的权利。重大调整将通过站内公告或邮件提前通知用户。',
            '若用户账户因违反服务条款被限制或封禁，该账户内的未消耗积分将被清零且不予恢复。',
          ],
        },
        {
          heading: '4. 用户行为规范',
          items: [
            '用户不得利用本平台进行任何违法活动。',
            '禁止发布垃圾信息、恶意链接、侵权内容或不当言论。',
            '不得通过技术手段干扰平台的正常运行。',
            '违反规定的账户将被限制或永久封禁。',
          ],
        },
        {
          heading: '5. 免责声明',
          items: [
            '本平台提供的 AI 分析和交易建议仅供参考，不构成投资建议。',
            '用户应自行承担所有投资决策的风险和后果。',
            '本平台不对因使用或不使用本服务而导致的任何损失承担责任。',
            '市场有风险，投资需谨慎。过往表现不代表未来收益。',
          ],
        },
        {
          heading: '6. 服务变更与终止',
          items: [
            '本平台保留随时修改或终止服务的权利。',
            '重大变更将通过站内通知或邮件提前告知。',
            '用户可随时删除账户并停止使用本服务。',
          ],
        },
        {
          heading: '7. 适用法律',
          items: [
            '本条款适用中华人民共和国法律（不含冲突法规则）。',
            '因本条款产生的争议，双方协商解决；协商不成的，提交平台所在地人民法院管辖。',
          ],
        },
        {
          heading: '8. 联系我们',
          items: [
            '如有任何问题，请联系：support@mytradewiseoc.com',
          ],
        },
      ],
    }
  : {
      title: 'Terms of Service',
      lastUpdated: 'Last updated: June 5, 2026',
      sections: [
        {
          heading: '1. Service Description',
          items: [
            'TradeAnchor (the "Platform") is a trading analysis, community interaction, and AI-assisted decision-making tool.',
            'The Platform provides, but is not limited to, the following features: trade record management, AI report generation, community content sharing, and a credits system.',
            'By registering for an account, you agree to be bound by these Terms.',
          ],
        },
        {
          heading: '2. User Account',
          items: [
            'You must provide accurate, complete, and current registration information.',
            'You are responsible for safeguarding your account and for all activities that occur under your account.',
            'If you suspect unauthorized use of your account, please notify us immediately.',
          ],
        },
        {
          heading: '3. Credits Earning & Usage',
          items: [
            '"Credits" are virtual reward units within the Platform, used exclusively for unlocking and consuming features and services on this website.',
            'Earning Credits: Users can earn credits by completing various tasks in the "Growth Plan" module, including but not limited to: first-time post browsing, creating trade records, publishing community posts, writing trading diaries, etc. Specific tasks and corresponding credit rewards are subject to real-time display on the Growth Plan page.',
            'Spending Credits: When using features such as AI report generation, AI follow-up conversations, or premium community content, credits will be deducted from your available balance according to the applicable rate. Exact consumption amounts are displayed at the time of each action.',
            'Credits cannot be withdrawn, transferred, gifted to third parties, or redeemed for any monetary value.',
            'Credits cannot be increased through top-up, purchase, or any payment method. All credits earned on this website are for consumption within this website only and may not be exchanged for cash or physical goods.',
            'The Platform reserves the right to adjust credit earning rules and consumption rates based on operational needs. Material changes will be communicated via in-app announcements or email in advance.',
            'If a user account is restricted or banned for violation of these Terms, any unspent credits in that account will be forfeited without restoration.',
          ],
        },
        {
          heading: '4. Acceptable Use Policy',
          items: [
            'You shall not use the Platform for any illegal purpose.',
            'Spamming, posting malicious links, infringing content, or inappropriate language is prohibited.',
            'You may not interfere with the proper functioning of the Platform through any technical means.',
            'Accounts in violation will be restricted or permanently banned.',
          ],
        },
        {
          heading: '5. Disclaimer',
          items: [
            'AI analyses and trading suggestions provided by this Platform are for reference only and do not constitute investment advice.',
            'Users bear full responsibility for all investment decisions and their consequences.',
            'The Platform shall not be liable for any losses resulting from the use or inability to use the service.',
            'Trading involves risk. Past performance does not guarantee future results.',
          ],
        },
        {
          heading: '6. Service Changes & Termination',
          items: [
            'The Platform reserves the right to modify or discontinue services at any time.',
            'Material changes will be communicated via in-app notification or email in advance.',
            'You may delete your account and stop using the service at any time.',
          ],
        },
        {
          heading: '7. Governing Law',
          items: [
            'These Terms shall be governed by the laws of the jurisdiction in which the Platform operates, without regard to conflict of law principles.',
            'Any disputes arising from these Terms shall first be resolved through negotiation; if unresolved, submitted to the courts of the Platform\'s location.',
          ],
        },
        {
          heading: '8. Contact Us',
          items: [
            'For any questions, please contact: support@mytradewiseoc.com',
          ],
        },
      ],
    };
---

<BaseLayout
  title={termsContent.title + ' - TradeAnchor'}
  description={termsContent.title}
  canonicalUrl={canonicalUrl}
>
  <Navbar />
  <main class="legal-page">
    <div class="container" style="max-width: 800px; margin: 0 auto; padding: 80px 20px 40px;">
      <header style="text-align: center; margin-bottom: 48px;">
        <h1 style="font-size: 2.4rem; font-weight: 800; color: var(--text-primary); margin-bottom: 8px;">
          {termsContent.title}
        </h1>
        <p style="font-size: 0.9rem; color: var(--text-secondary);">{termsContent.lastUpdated}</p>
      </header>

      {termsContent.sections.map((section) => (
        <section style="margin-bottom: 32px;">
          <h2 style="
            font-size: 1.3rem;
            font-weight: 700;
            color: var(--text-primary);
            padding-bottom: 10px;
            border-bottom: 2px solid var(--primary);
            margin-bottom: 16px;
          ">{section.heading}</h2>
          <ul style="list-style: none; padding: 0; margin: 0;">
            {section.items.map((item) => (
              <li style="
                color: var(--text-secondary);
                line-height: 1.8;
                padding: 6px 0;
                padding-left: 20px;
                position: relative;
              ">
                <span style="
                  position: absolute;
                  left: 0;
                  top: 14px;
                  width: 6px;
                  height: 6px;
                  background: var(--primary);
                  border-radius: 50%;
                "></span>
                {item}
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </main>
  <RiskDisclaimer text={t.risk} />
  <Footer footer={t.footer} />
</BaseLayout>
