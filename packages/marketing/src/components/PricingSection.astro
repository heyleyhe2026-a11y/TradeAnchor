---
import en from '../i18n/en.ts';
import zh from '../i18n/zh.ts';

interface Props {
  lang?: 'en' | 'zh';
}

const { lang = 'en' } = Astro.props;
const t = lang === 'zh' ? zh : en;
const spaBase = '';
---

<section class="pricing-section" id="pricing">
  <div class="container">
    <div class="section-header">
      <h2>{t.pricing.sectionTitle}</h2>
      <p>{t.pricing.sectionSubtitle}</p>
    </div>

    <div class="pricing-grid">
      {t.pricing.tiers.map((tier) => (
        <article class={`pricing-card ${tier.highlighted ? 'highlighted' : ''}`}>
          <h3>{tier.name}</h3>
          <div class="price-row">
            <span class="price">{tier.price}</span>
            <span class="period">{tier.period}</span>
          </div>
          <ul class="feature-list">
            {tier.features.map((feat) => (
              <li><span class="check">✓</span> {feat}</li>
            ))}
          </ul>
          <a
            href={`${spaBase}/register`}
            class={`btn ${tier.highlighted ? 'btn-primary' : 'btn-outline'}`}
            class:btn-full
          >
            {t.pricing.buttonChoosePlan}
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .pricing-section {
    padding: 4rem 0;
    border-top: 1px solid rgba(255,255,255,0.04);
  }
  .section-header { text-align: center; margin-bottom: 3rem; }
  .section-header h2 {
    font-size: 1.75rem;
    font-weight: 800;
    color: #fff;
    margin-bottom: 0.6rem;
  }
  .section-header p {
    font-size: 1rem;
    color: var(--text-muted);
    max-width: 550px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    align-items: stretch;
  }
  .pricing-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    transition: all 0.3s;
    height: 100%;
  }
  .pricing-card:not(.highlighted):hover {
    transform: translateY(-4px);
    border-color: rgba(0,212,170,0.15);
  }
  .pricing-card.highlighted {
    transform: scale(1.03);
    border: 2px solid var(--accent);
    box-shadow: 0 0 30px rgba(0,212,170,0.15);
    z-index: 2;
  }

  .pricing-card h3 {
    font-size: 1.15rem;
    font-weight: 700;
    color: inherit;
    margin-bottom: 0.75rem;
  }
  .pricing-card.highlighted h3 { color: var(--accent); }
  .pricing-card:not(.highlighted) h3 { color: #f1f5f9; }

  .price-row {
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
    margin-bottom: 1.5rem;
  }
  .price {
    font-size: 2.25rem;
    font-weight: 800;
    color: #fff;
    line-height: 1;
  }
  .period { font-size: 0.9rem; color: var(--text-muted); }

  .feature-list {
    list-style: none;
    flex: 1;
    margin-bottom: 1.5rem;
  }
  .feature-list li {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    font-size: 0.9rem;
    color: #cbd5e1;
    margin-bottom: 0.85rem;
  }
  .check {
    color: var(--accent);
    font-weight: 700;
    flex-shrink: 0;
    font-size: 0.85rem;
  }

  .btn-full { width: 100%; justify-content: center; }

  @media (max-width: 900px) {
    .pricing-grid { grid-template-columns: 1fr; max-width: 420px; margin: 0 auto; }
    .pricing-card.highlighted { transform: none; order: -1; }
  }
</style>
