# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/tradewise
REDIS_URL=redis://localhost:6379
MONGODB_URL=mongodb://localhost:27017/tradewise

# JWT Configuration
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=30m
REFRESH_TOKEN_EXPIRES_IN=30d

# Email / SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM_ADDRESS=noreply@mytradewiseoc.com
EMAIL_FROM_NAME=TradeAnchor

# Frontend URL (for email verification links)
FRONTEND_URL=http://localhost:5173

# AI Configuration
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# ofox.ai Unified Gateway (OpenAI + Claude + Gemini via single API)
OFOX_API_KEY=your-ofox-api-key
OFOX_BASE_URL=https://api.ofox.ai/v1

# Community UGC translation (via OFOX)
TRANSLATION_MODEL=gpt-5-mini

# Payment Gateway Configuration
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# FastSpring Configuration
FASTSPRING_STORE_ID=tradewise_store
FASTSPRING_STORE_URL=https://sites.fastspring.com/tradewise_store/product
FASTSPRING_API_USERNAME=your-fastspring-api-username
FASTSPRING_API_PASSWORD=your-fastspring-api-password
FASTSPRING_WEBHOOK_SECRET=your-fastspring-webhook-hmac-secret

# Creem Configuration (Merchant of Record)
PAYMENT_PROVIDER=creem
CREEM_API_KEY=creem_live_your-api-key
CREEM_WEBHOOK_SECRET=whsec_your-webhook-secret
CREEM_API_BASE=https://api.creem.io
CREEM_PRODUCT_PRO=prod_your-pro-product-id
CREEM_PRODUCT_PREM=prod_your-premium-product-id
CREEM_SUCCESS_URL=https://mytradewiseoc.com/subscription

# Storage Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=tradewise-uploads
AWS_REGION=us-east-1

# OAuth Configuration - Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth Configuration - GitHub
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# OAuth Configuration - Amazon Builder ID (Login with Amazon)
AMAZON_CLIENT_ID=your-amazon-client-id
AMAZON_CLIENT_SECRET=your-amazon-client-secret

# Economic Calendar API (for AI report event dates — get real event dates instead of AI guessing)
# Option 1: Finnhub (recommended, free tier) — register at https://finnhub.io -> Dashboard -> API key
FINNHUB_API_KEY=your-finnhub-api-key
# Option 2: Alpha Vantage (reuse ALPHA_VANTAGE_API_KEY above if already configured)
# ECONOMIC_CALENDAR_PROVIDER=finnhub   # "finnhub" or "alpha_vantage", default: finnhub

# Market data / K-line charts (Twelve Data) — https://twelvedata.com/account/api-keys
# Backend only; never expose in frontend. Used when dashboard chart feature is enabled.
TWELVEDATA_API_KEY=your-twelvedata-api-key
# TWELVEDATA_BASE_URL=https://api.twelvedata.com

# Production monitoring (optional)
# METRICS_TOKEN=random-secret-for-prometheus-scraping
# In production, /metrics allows private-network IPs (Docker/Prometheus) or Bearer METRICS_TOKEN.
# Swagger (/api-docs) is disabled when NODE_ENV=production.

# Dev seed / smoke-test accounts (optional — do not use defaults in production)
SEED_PASSWORD=ChangeMeInDev123!
SEED_TEST_EMAIL=free@example.com
