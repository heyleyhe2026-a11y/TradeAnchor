# Root env for docker-compose.prod.yml (copy to .env on the server — never commit .env)
# See packages/backend/.env.example for the full list of application variables.

POSTGRES_DB=tradewise
POSTGRES_USER=tradewise
POSTGRES_PASSWORD=change-me
REDIS_PASSWORD=change-me
MONGO_USERNAME=tradewise
MONGO_PASSWORD=change-me

JWT_SECRET=change-me-use-long-random-string
JWT_REFRESH_SECRET=change-me-use-long-random-string

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

CORS_ORIGIN=https://your-domain.com
API_BASE_URL=https://api.your-domain.com

# Optional — add keys from packages/backend/.env.example as needed
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
TWELVEDATA_API_KEY=
SENTRY_DSN=
